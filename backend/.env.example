# Copy this file to .env and fill in your real values.

# MongoDB Atlas (or any MongoDB) connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net
MONGODB_DB_NAME=guru_ai

# JWT
JWT_SECRET=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# AI provider — set PROVIDER to "openai" or "granite" (legacy, currently unused by any agent)
AI_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
GRANITE_API_KEY=
GRANITE_API_URL=

# Groq — this is the one that actually matters. Powers Lesson, Language, Quiz,
# Community Knowledge, and Voice (STT) agents. Free key: https://console.groq.com/keys
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# CORS
FRONTEND_ORIGIN=http://localhost:3000
